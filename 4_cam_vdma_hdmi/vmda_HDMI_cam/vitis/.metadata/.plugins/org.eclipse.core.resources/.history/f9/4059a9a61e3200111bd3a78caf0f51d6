#include <stdio.h>
#include "xil_io.h"
#include "xparameters.h"

//VDMA 控制 基地址
#define XPAR_AXI_VDMA_0_BASEADDR 0x43000000U
#define XPAR_AXI_VDMA_0_HIGHADDR 0x4300FFFFU

//VDMA 各个寄存器偏移地址
#define MM2S_VDMACR 		0x00 //开启VDMA
#define MM2S_START_ADDRESS 	0x5c //起始地址
#define MM2S_FRMDLY_STRIDE 	0x58 //步长
#define MM2S_HSIZE 			0x54 //行尺寸
#define MM2S_VSIZE 			0x50 //列尺寸

//输入参数
#define VDMA_OPEN			0x1
#define	VDMA_START_ADDR		0x10000000
#define VDMA_STRIDE			0x00000A00 //一行到另外一行
#define VDMA_HSIZE			0x00000A00 //1280*2 按照字节计算
#define VDMA_VSIZE			0x000002D0 //720

int  main(){

	Xil_Out32(XPAR_AXI_VDMA_0_BASEADDR+MM2S_VDMACR			,0x1);
	Xil_Out32(XPAR_AXI_VDMA_0_BASEADDR+MM2S_START_ADDRESS	,0x1);
	Xil_Out32(XPAR_AXI_VDMA_0_BASEADDR+MM2S_FRMDLY_STRIDE	,0x1);
	Xil_Out32(XPAR_AXI_VDMA_0_BASEADDR+MM2S_HSIZE			,0x1);
	Xil_Out32(XPAR_AXI_VDMA_0_BASEADDR+MM2S_VSIZE			,0x1);
	return 0;
}
